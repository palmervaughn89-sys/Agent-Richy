FROM python:3.11-slim

WORKDIR /app

# Install dependencies first (layer caching)
COPY agent-richy-v2/backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy backend application code
COPY agent-richy-v2/backend/ /app/

# Copy knowledge base for RAG (root data/ -> /app/knowledge_base)
COPY data/knowledge_base /app/knowledge_base

# Copy investment data
COPY data/investments.json /app/data/investments.json

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
